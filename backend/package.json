{
  "name": "backend",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "migrate": "tsx src/infrastructure/migrate.ts",
    "lint": "eslint .",
    "test": "vitest run --reporter=default --reporter=json --outputFile=test-result.json",
    "test:unit": "vitest run --config vitest.unit.config.ts --reporter=default",
    "test:integration": "vitest run --config vitest.integration.config.ts --reporter=default",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "eslint-plugin-unused-imports": "^4.4.1",
    "hono": "^4.12.14",
    "@hono/node-server": "^1.14.3",
    "hono-openapi": "^1.3.0",
    "mysql2": "^3.22.2",
    "type-check": "^0.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "tsx": "^4.19.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^10.2.1",
    "eslint-plugin-jsdoc": "^62.9.0",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  }
}
